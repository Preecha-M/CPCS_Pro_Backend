## Core
# Port for uvicorn
PORT=8000

FRONTEND_URL=http://localhost:5173

## MongoDB
# Local example: mongodb://localhost:27017
# Atlas example: mongodb+srv://user:pass@cluster/db?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=riceapp

## Supabase (optional, required for storage upload features)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=rice-images

## LINE Messaging API (required for webhook /callback)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

## HuggingFace Space / image model 
HF_SPACE=Teayear/Rice_EfficientNetB1
CLIP_THRESHOLD=0.45

## Auth / session
EXPIRY_MINUTES=10

## Gemini 
GEMINI_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

